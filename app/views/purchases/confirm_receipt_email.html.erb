<main class="grid divide-y divide-border bg-filled border border-border rounded mx-auto my-4 h-min max-w-md w-[calc(100%-2rem)]">
  <header class="flex flex-col gap-4 p-4 text-center">
    <h2>Confirm your email address</h2>
    <p>Please enter the email address used to purchase this product to view your receipt.</p>
  </header>
  <%= form_tag(receipt_purchase_path(@purchase.external_id), method: "get", class: "flex flex-col gap-4 p-4") do %>
    <%= label_tag :email, "Email address:", class: "form-label" %>
    <%= email_field_tag :email, nil, placeholder: "Email address", required: true, class: "w-full border border-border rounded bg-background px-4 py-3 text-base leading-snug font-[inherit] outline-none focus:ring-2 focus:ring-accent" %>
    <%= button_tag "View receipt", type: "submit", class: "inline-flex items-center justify-center gap-2 cursor-pointer border border-border rounded font-[inherit] no-underline transition-transform hover:-translate-1 hover:shadow active:translate-0 active:shadow-none disabled:opacity-30 disabled:hover:translate-0 disabled:hover:shadow-none px-4 py-3 text-base leading-snug bg-primary text-primary-foreground hover:bg-accent hover:text-accent-foreground w-full", name: nil %>
  <% end %>
</main>
<% content_for :footer do %>
  <%= default_footer_content %>
<% end %>
